{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$(git rev-parse --show-toplevel)/.agents/scripts/protect-version-file.sh\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$(git rev-parse --show-toplevel)/.agents/scripts/pre-pr-gate.sh\""
          },
          {
            "type": "command",
            "command": "\"$(git rev-parse --show-toplevel)/.agents/scripts/publish-version-gate.sh\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$(git rev-parse --show-toplevel)/.agents/scripts/sanitize-source-code.sh\""
          },
          {
            "type": "command",
            "command": "\"$(git rev-parse --show-toplevel)/.agents/scripts/update-copyright.sh\""
          }
        ]
      }
    ]
  }
}
